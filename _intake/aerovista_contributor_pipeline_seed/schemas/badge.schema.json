{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aerovista/schemas/badge.schema.json",
  "title": "Badge Spec",
  "type": "object",
  "required": [
    "id",
    "title",
    "version",
    "requirements"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9\\-_\\.]{2,64}$"
    },
    "title": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string"
    },
    "icon": {
      "type": "string",
      "description": "Path or URL to badge icon"
    },
    "requirements": {
      "type": "object",
      "required": [
        "evidence_rules"
      ],
      "properties": {
        "evidence_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "event",
              "min_count"
            ],
            "properties": {
              "event": {
                "type": "string"
              },
              "min_count": {
                "type": "integer",
                "minimum": 1
              },
              "props_match": {
                "type": "object"
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}